	(CVTLQ
	   (format destination "  CVTLQ(~A, ~A, ~A, ~A, ~A);~%"
		   (regnum (fixarg arg3)) (fixarg arg3)
		   (fixarg arg1) (regnum (fixarg arg2)) (fixarg arg2)))

	(CVTTQ
	   (format destination "  CVTTQ(~A, ~A, ~A, ~A, ~A);~%"
