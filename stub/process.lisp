	(FETCH)
	(FETCH_M)

	(LDA
	 (check-comment arg4)
	 (if (listp arg3)
	     (setq arg3 (car arg3)))
	 (cond
	  ((eq arg2 0)
	   (format destination "  ~A = ~A;~%"
		   (fixarg arg1) (fixarg arg3)))
	  ((or (numberp arg2) (isconstant arg2) (eq arg3 'zero))
