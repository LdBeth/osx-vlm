	     (format destination "  ~A = (u8)~A;~%"
		     (fixarg arg3) (fixarg arg1))
	   (format destination "  ~A = (u8)(~A >> ((~A&7)*8));~%"
		   (fixarg arg3) (fixarg arg1) (fixarg arg2))))

	(EXTWL
	 (check-comment arg4)
