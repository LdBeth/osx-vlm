	     (format destination "  ~A = (u64)(~A) << 16;~%"
		     (fixarg arg1) (fixarg arg2))
	   (if (or (numberp arg2) (isconstant arg2))
	       (format destination "  ~A = ~A + ((u64)(~A) << 16);~%"
		       (fixarg arg1) (fixarg arg3) (fixarg arg2))
