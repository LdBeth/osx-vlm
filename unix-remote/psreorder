#!/usr/bin/env python3
"""psreorder -- fix Genera hardcopy PostScript captured from Open Genera.

Two independent, opt-out-able fixes, applied as a stdin -> stdout filter:

1. Reverse page order.  Open Genera's LGP2 hardcopy driver spools pages
   LIFO: the DSC %%Page comments in a job run N, N-1, ... 1 instead of
   1 ... N, so anything that prints or renders the file in physical order
   shows the last page first.  The %%Page ordinal is otherwise unused by
   the PostScript itself -- each page just ends with "showpage" (via the
   NextPage procedure, whose true/false argument is popped and ignored) --
   so correcting the order is a pure text rearrangement of the %%Page
   chunks, the same trick classic psutils tools like psselect/pstops use.

2. Repair modern-font encoding mismatches (--no-patch-fonts to disable).  The
   LGP2 driver reaches high-bit glyphs by raw character code, assuming the old
   Type-1 resident fonts' encoding; two things break on today's fonts:
   * The SAGE formatter strands the source newline before every @end(...) as a
     literal #\Return (Symbolics code 141 = 0o215), emitted as "141 cs show".
     Code 141 is .notdef in every font, but Genera's downloaded bitmap fonts
     define .notdef as an empty glyph (invisible) while the resident core fonts
     image it as a visible box (e.g. the title page's "Draft <box> July 2026").
     We remap 141 -> /space in the 13 core fonts to match the bitmap fonts.
   * In /Symbol the driver emits 183 (0o267) and 190 (0o276) for /bullet and
     /arrowhorizex, which the old Type-1 SymbolEncoding carried at those code
     points but the modern (TrueType) Symbol does not -- so Acrobat Distiller
     resolves them to .notdef and drops them from the embedded subset (the
     em-dash-like rule between clauses vanishes).  We restore them by glyph
     name, which the modern Symbol still provides.
   No page content is touched; only the prolog's font dicts are reencoded.

This is a stdin -> stdout filter, not wired into lpdd: run it over a live
job or an already-spooled file.

    gs foo.ps | psreorder | lpr
    psreorder < ~/genera-spool/genera-....ps > fixed.ps

If the input doesn't look like a clean Genera N..1 reversed job (no
%%Page comments, out-of-order ordinals, missing/mismatched %%Pages
count), the page order is left unchanged; if it has no /IntFonts prolog,
the font patch is skipped.  Either way unrecognized input passes through.
"""

import argparse
import logging
import re
import sys

PAGE_RE = re.compile(rb"^%%Page:\s+(\S+)\s+(-?\d+)\s*$")
PAGES_RE = re.compile(rb"^%%Pages:\s+(\d+)\s*$")
TRAILER_RE = re.compile(rb"^%%Trailer\b")
INTFONTS_RE = re.compile(rb"^/IntFonts\s*\[")

# PostScript injected into the prolog to fix two encoding mismatches (see the
# module docstring).  It reencodes the 13 core PostScript fonts -- exactly the
# resident set the LGP2 driver's make-builtin-lgp2-font can emit -- by (a)
# remapping code 141 (stray #\Return) to /space, matching the empty .notdef of
# Genera's downloaded bitmap fonts, and (b) for /Symbol only, restoring the two
# glyphs the modern Symbol lost at their old Type-1 code points: 183 -> /bullet
# and 190 -> /arrowhorizex.  Each patched code is emitted by the driver as an
# isolated run with its own moveto, so a changed advance width is never visible,
# and ASCII text (batched via the "s" operator) is untouched.  Must land before
# /IntFonts (whose findfonts must get the patched fonts) and before the initial
# `save` (NextPage does restore/save between pages, which would otherwise roll
# the patch back on page 2+); injecting right before the /IntFonts line does both.
PATCH_MARKER = b"psrPatchFont"
PATCH_SNIPPET = b"""\
%%BeginProcSet: psreorder-font-encoding 1.1
% linux-vlm psreorder reencodes the 13 core fonts to fix two Genera-vs-modern
% mismatches: (a) #\\Return (code 141 = 0o215), stranded before @end and imaged
% as a .notdef box by the resident fonts, is remapped to /space (blank) to match
% Genera's bitmap fonts' empty .notdef; (b) /Symbol reaches /bullet and
% /arrowhorizex by the old Type-1 code points 183 (0o267) and 190 (0o276), which
% the modern (TrueType) Symbol lacks there -- so Distiller drops them -- and we
% restore them by glyph name.
/psrBlankCode 141 def
/psrPatchFont {                       % /FontName  ->  -
  dup findfont
  dup length dict begin               % copy the font dict, skipping /FID
    { 1 index /FID ne { def } { pop pop } ifelse } forall
    /Encoding Encoding 256 array copy def
    Encoding psrBlankCode /space put
    dup /Symbol eq {                  % restore glyphs the modern Symbol hides
      Encoding 183 /bullet put         % old Type-1 SymbolEncoding 0o267
      Encoding 190 /arrowhorizex put   % old Type-1 SymbolEncoding 0o276
    } if
    currentdict
  end
  definefont pop
} bind def
[/Helvetica /Helvetica-Bold /Helvetica-Oblique /Helvetica-BoldOblique
 /Times-Roman /Times-Bold /Times-Italic /Times-BoldItalic
 /Courier /Courier-Bold /Courier-Oblique /Courier-BoldOblique /Symbol]
{ psrPatchFont } forall
%%EndProcSet
"""

log = logging.getLogger("psreorder")


def split_lines(data):
    """Split into lines keeping line terminators, like bytes.splitlines(True)."""
    return data.splitlines(keepends=True)


def find_declared_pages(lines):
    """Return the %%Pages: count from the header, or None if absent/unparseable."""
    for line in lines:
        if line.startswith(b"%%EndComments"):
            break
        m = PAGES_RE.match(line)
        if m:
            return int(m.group(1))
    return None


def split_chunks(lines):
    """Split into (header, [(ordinal, chunk_bytes), ...], trailer).

    header is everything before the first %%Page: line; trailer is the
    %%Trailer line onward (or b"" if none found); each page chunk runs
    from its %%Page: line up to the next %%Page:/%%Trailer line.
    """
    page_starts = []
    ordinals = []
    trailer_start = None
    for i, line in enumerate(lines):
        m = PAGE_RE.match(line)
        if m:
            page_starts.append(i)
            ordinals.append(int(m.group(2)))
        elif trailer_start is None and TRAILER_RE.match(line):
            trailer_start = i

    if not page_starts:
        return None

    # Each page runs up to the next %%Page:, and the last up to the trailer.
    end = trailer_start if trailer_start is not None else len(lines)
    ends = page_starts[1:] + [end]
    header = b"".join(lines[: page_starts[0]])
    pages = [(ordinal, b"".join(lines[start:stop]))
             for ordinal, start, stop in zip(ordinals, page_starts, ends)]
    trailer = b"".join(lines[trailer_start:]) if trailer_start is not None else b""
    return header, pages, trailer


def reorder(data):
    """Return (output_bytes, reordered_bool)."""
    lines = split_lines(data)
    split = split_chunks(lines)
    if split is None:
        return data, False  # no %%Page comments at all -- nothing to do

    header, pages, trailer = split
    ordinals = [ordinal for ordinal, _ in pages]
    expected = list(range(len(pages), 0, -1))
    declared = find_declared_pages(lines)

    if ordinals != expected or (declared is not None and declared != len(pages)):
        log.warning(
            "not a clean reversed Genera job (ordinals=%s, %%%%Pages=%s) -- "
            "passing through unchanged",
            ordinals, declared)
        return data, False

    reordered = b"".join(chunk for _, chunk in reversed(pages))
    return header + reordered + trailer, True


def patch_fonts(data):
    """Return (output_bytes, patched_bool).

    Inject PATCH_SNIPPET immediately before the /IntFonts line so the core
    fonts get the reencoding (blank 141; restore Symbol 183/190).  No-op
    (unchanged) if the patch is already present or the input has no /IntFonts
    prolog (not a Genera LGP2 job).
    """
    if PATCH_MARKER in data:
        return data, False  # already patched -- idempotent
    lines = split_lines(data)
    for i, line in enumerate(lines):
        if INTFONTS_RE.match(line):
            lines.insert(i, PATCH_SNIPPET)
            return b"".join(lines), True
    log.warning("no /IntFonts prolog found -- skipping font patch")
    return data, False


def main(argv=None):
    p = argparse.ArgumentParser(
        description="Fix Genera hardcopy PostScript (reverse page order + repair "
                    "font encodings); stdin -> stdout")
    p.add_argument("-v", "--verbose", action="count", default=0,
                   help="-v info, -vv debug")
    p.add_argument("--no-patch-fonts", dest="patch_fonts", action="store_false",
                   default=True,
                   help="do not repair font encodings (blank code 141, restore "
                        "Symbol 183/190); only reorder pages")
    args = p.parse_args(argv)

    logging.basicConfig(
        level=[logging.WARNING, logging.INFO, logging.DEBUG][min(args.verbose, 2)],
        format="%(asctime)s psreorder %(levelname)s %(message)s")

    data = sys.stdin.buffer.read()
    # Independent transforms on disjoint regions (page bodies vs. prolog header);
    # order is immaterial.
    data, reordered = reorder(data)
    patched = False
    if args.patch_fonts:
        data, patched = patch_fonts(data)
    log.info("pages %s, fonts %s (%d bytes)",
             "reordered" if reordered else "unchanged",
             "patched" if patched else "unchanged", len(data))
    sys.stdout.buffer.write(data)
    return 0


if __name__ == "__main__":
    sys.exit(main())
