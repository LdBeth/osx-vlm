		   (fixarg arg1) (regnum (fixarg arg2)) (fixarg arg2)))

	(M-DIVQU
	 (check-comment arg4)
	 (format destination "  ~A = ~A / ~A;~%"
		 (fixarg arg3)
		 (fixarg arg1)
		 (fixarg arg2)))

	(EXTERNAL-BRANCH
